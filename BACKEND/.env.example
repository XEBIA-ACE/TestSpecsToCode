# ============================================================
# User Management Service — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ============================================================

# ---------------------------------------------------------
# SQLite database
# ---------------------------------------------------------
# Path to the SQLite database file. The containing folder and the file
# itself are auto-created on first run — no manual database setup required.
DATABASE_PATH=./data/app.db

# ---------------------------------------------------------
# Password policy
# ---------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRES_UPPERCASE=true
PASSWORD_REQUIRES_LOWERCASE=true
PASSWORD_REQUIRES_DIGIT=true
PASSWORD_REQUIRES_SPECIAL=true

# ---------------------------------------------------------
# Activation token
# ---------------------------------------------------------
# How many hours until the activation token expires (default: 24)
TOKEN_EXPIRY_HOURS=24

# Base URL used to build the activation link sent in the email.
# REQUIRED. Example: https://app.example.com
ACTIVATION_BASE_URL=http://localhost:3000

# ---------------------------------------------------------
# bcrypt
# ---------------------------------------------------------
# Cost factor for bcrypt password hashing. MUST be >= 12.
BCRYPT_COST_FACTOR=12

# ---------------------------------------------------------
# Transactional outbox worker
# ---------------------------------------------------------
# How often (ms) the outbox worker polls for queued records (default: 30000)
OUTBOX_POLL_INTERVAL_MS=30000
# Maximum delivery retries before marking a record as failed (default: 1)
OUTBOX_MAX_RETRIES=1

# ---------------------------------------------------------
# SendGrid
# ---------------------------------------------------------
# REQUIRED. Your SendGrid API key. Keep secret — never log this value.
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# REQUIRED. The SendGrid dynamic template ID for the activation email.
SENDGRID_TEMPLATE_ID=d-your_template_id_here

# REQUIRED. Verified SendGrid Single Sender address used as the "from" on outgoing emails.
FROM_EMAIL=noreply@yourdomain.com
# Optional display name shown alongside FROM_EMAIL.
FROM_NAME=User Management Service

# ---------------------------------------------------------
# Admin auth
# ---------------------------------------------------------
# Required bearer token used by admin endpoints.
ADMIN_BEARER_TOKEN=your_admin_bearer_token_here

# ---------------------------------------------------------
# OTP delivery via email (F-02)
# NOTE: delivery uses email, not SMS, for this deployment — see
# .kiro/specs/otp/tasks.md task 2 deviation note. OTP emails reuse the
# existing SendGrid-backed EmailDeliveryPort.
# ---------------------------------------------------------
# Number of digits in a generated OTP (default: 6)
OTP_LENGTH=6
# Minutes until an issued OTP expires (default: 10)
OTP_TTL_MINUTES=10
# Max OTP send/resend attempts allowed per rate-limit window (default: 5)
OTP_MAX_ATTEMPTS_PER_WINDOW=5
# Rolling rate-limit window size in minutes (default: 15)
OTP_RATE_LIMIT_WINDOW_MINUTES=15
# Hash algorithm used to hash OTP values before persistence (default: sha256)
OTP_HASH_ALGORITHM=sha256
# REQUIRED. Secret key used to HMAC-hash OTP codes before persistence. Keep secret — never log this value.
OTP_HASH_SECRET=your_otp_hash_secret_here
# Whether the OTP delivery adapter actually dispatches messages (default: true)
SMS_PROVIDER_ENABLED=true
# REQUIRED. The SendGrid dynamic template ID for the OTP email.
OTP_EMAIL_TEMPLATE_ID=d-your_otp_template_id_here

# ---------------------------------------------------------
# Redis (OTP rate limiting)
# ---------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------
# User Login (F-03): session policy
# ---------------------------------------------------------
# Session lifetime in seconds (default: 3600 / 1 hour)
SESSION_EXPIRY_SECONDS=3600
# Consecutive failed logins before an account is temporarily locked (default: 5)
LOGIN_LOCKOUT_THRESHOLD=5
# Lockout duration in minutes once the threshold is reached (default: 15)
LOGIN_LOCKOUT_DURATION_MINUTES=15

# ---------------------------------------------------------
# User Login (F-03): password recovery
# ---------------------------------------------------------
# How many hours until a password-recovery token expires (default: 1)
PASSWORD_RECOVERY_TOKEN_EXPIRY_HOURS=1
# Base URL used to build the password-reset link sent in the recovery email.
# REQUIRED. Example: https://app.example.com
PASSWORD_RECOVERY_BASE_URL=poonam.biswas@xebia.com
# REQUIRED. The SendGrid dynamic template ID for the password-recovery email.
PASSWORD_RECOVERY_EMAIL_TEMPLATE_ID=d-your_recovery_template_id_here

# ---------------------------------------------------------
# Account Deletion (F-04)
# ---------------------------------------------------------
# Deletion is confirmed via a 6-digit OTP code emailed to the user and
# entered while still logged in (not a clickable link). The code is hashed
# with the same OTP_HASH_SECRET/OTP_HASH_ALGORITHM used by the OTP feature
# above — no separate secret is required here.
# How many minutes until a deletion-confirmation OTP code expires (default: OTP_TTL_MINUTES's default, 10)
ACCOUNT_DELETION_OTP_EXPIRY_MINUTES=10
# REQUIRED. The SendGrid dynamic template ID for the deletion-confirmation-request email.
ACCOUNT_DELETION_REQUEST_EMAIL_TEMPLATE_ID=d-your_deletion_request_template_id_here
# REQUIRED. The SendGrid dynamic template ID for the post-deletion notice email.
ACCOUNT_DELETION_NOTICE_EMAIL_TEMPLATE_ID=d-your_deletion_notice_template_id_here

# ---------------------------------------------------------
# Application / server
# ---------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------
# CORS
# ---------------------------------------------------------
# Optional. If unset, the API reflects whatever Origin header the browser
# sends (safe here since auth is Bearer-token based, not cookie-based).
# Set this to your frontend's deployed origin (e.g. https://app.example.com)
# once known, to lock CORS down to that origin only.
FRONTEND_ORIGIN=
