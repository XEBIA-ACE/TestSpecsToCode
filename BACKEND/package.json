    "@types/jest": "29.5.12",
    "@types/node": "20.14.10",
    "@types/supertest": "6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "9.0.8",
    "@types/yamljs": "^0.2.34",
